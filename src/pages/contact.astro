---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contactez Sematec" description="Contactez Sematec pour un devis gratuit ou une intervention d'urgence en plomberie à Bruxelles. Disponible 24/7.">
	<Header />
	
	<main class="page-main">
		<section class="page-hero">
			<div class="container text-center animate-fade-in">
				<h1>Nous <span>Contacter</span></h1>
				<p class="subtitle">Une urgence ? Un projet d'installation ? N'hésitez pas à nous joindre.</p>
			</div>
		</section>

		<section class="contact-section container">
			<div class="contact-grid">
				<div class="contact-info">
					<h2>Informations de contact</h2>
					<p>Notre équipe est à votre disposition 24h/24 et 7j/7 pour toute urgence de plomberie à Bruxelles.</p>
					
					<div class="info-item">
						<span class="icon">📍</span>
						<div>
							<h3>Adresse</h3>
							<p>1000 Bruxelles, Belgique</p>
						</div>
					</div>
					
					<div class="info-item">
						<span class="icon">📞</span>
						<div>
							<h3>Téléphone</h3>
							<p><a href="tel:+3221234567">+32 2 123 45 67</a></p>
							<span class="badge-small">Disponible 24/7</span>
						</div>
					</div>
					
					<div class="info-item">
						<span class="icon">✉️</span>
						<div>
							<h3>Email</h3>
							<p><a href="mailto:info@sematec-plomberie.be">info@sematec-plomberie.be</a></p>
						</div>
					</div>
				</div>
				
				<div class="contact-form-container">
					<h2>Demande de devis</h2>
					<form class="contact-form" action="#" method="POST">
						<div class="form-group">
							<label for="name">Nom complet</label>
							<input type="text" id="name" name="name" required placeholder="Votre nom">
						</div>
						
						<div class="form-group">
							<label for="phone">Téléphone</label>
							<input type="tel" id="phone" name="phone" required placeholder="Votre numéro">
						</div>
						
						<div class="form-group">
							<label for="service">Service souhaité</label>
							<select id="service" name="service">
								<option value="urgence">Dépannage d'urgence</option>
								<option value="installation">Installation sanitaire</option>
								<option value="chauffage">Chauffage & Chauffe-eau</option>
								<option value="devis">Demande de devis général</option>
							</select>
						</div>
						
						<div class="form-group">
							<label for="message">Message</label>
							<textarea id="message" name="message" rows="5" required placeholder="Décrivez votre besoin..."></textarea>
						</div>
						
						<button type="submit" class="btn btn-submit">Envoyer la demande</button>
					</form>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>

<style>
	.page-main {
		padding-top: 100px;
	}

	.page-hero {
		padding: 60px 0;
		background: linear-gradient(180deg, rgba(0, 229, 255, 0.05) 0%, transparent 100%);
	}

	.text-center {
		text-align: center;
	}

	h1 {
		font-size: 3.5rem;
		margin-bottom: 20px;
	}

	h1 span {
		color: var(--primary);
	}

	.subtitle {
		font-size: 1.2rem;
		color: var(--text-muted);
		max-width: 600px;
		margin: 0 auto;
	}

	.contact-section {
		padding: 60px 20px;
	}

	.contact-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 60px;
	}

	.contact-info h2, .contact-form-container h2 {
		font-size: 2rem;
		margin-bottom: 20px;
	}

	.contact-info > p {
		color: var(--text-muted);
		margin-bottom: 40px;
		font-size: 1.1rem;
	}

	.info-item {
		display: flex;
		gap: 20px;
		margin-bottom: 30px;
		background: var(--bg-card);
		padding: 20px;
		border-radius: 12px;
		border: 1px solid rgba(255,255,255,0.05);
	}

	.info-item .icon {
		font-size: 2rem;
	}

	.info-item h3 {
		font-size: 1.2rem;
		margin-bottom: 5px;
	}

	.info-item p, .info-item a {
		color: var(--text-muted);
		transition: color 0.3s ease;
	}

	.info-item a:hover {
		color: var(--primary);
	}

	.badge-small {
		display: inline-block;
		background: rgba(255, 51, 102, 0.1);
		color: var(--accent);
		padding: 4px 8px;
		border-radius: 10px;
		font-size: 0.8rem;
		margin-top: 5px;
	}

	.contact-form-container {
		background: var(--bg-card);
		padding: 40px;
		border-radius: 20px;
		border: 1px solid rgba(255,255,255,0.05);
		box-shadow: 0 20px 40px rgba(0,0,0,0.3);
	}

	.form-group {
		margin-bottom: 20px;
	}

	.form-group label {
		display: block;
		margin-bottom: 8px;
		color: var(--text-main);
		font-weight: 600;
	}

	.form-group input, 
	.form-group select, 
	.form-group textarea {
		width: 100%;
		padding: 12px 16px;
		background: rgba(0,0,0,0.2);
		border: 1px solid rgba(255,255,255,0.1);
		border-radius: 8px;
		color: var(--text-main);
		font-family: inherit;
		transition: border-color 0.3s ease;
	}

	.form-group input:focus, 
	.form-group select:focus, 
	.form-group textarea:focus {
		outline: none;
		border-color: var(--primary);
	}

	.btn-submit {
		width: 100%;
		padding: 16px;
		font-size: 1.1rem;
		margin-top: 10px;
	}

	@media (max-width: 768px) {
		h1 { font-size: 2.5rem; }
		.contact-grid { grid-template-columns: 1fr; }
		.contact-form-container { padding: 20px; }
	}
</style>
